\@writefile{toc}{\contentsline {subsubsection}{\numberline {1.1.7}Rendering Performance}{4}{subsubsection.1.1.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  Median rendering speed as a function of active Gaussian count across five pretrained blocks. Each point represents the mean of the median FPS values obtained from five repeated runs, where each run contains 300 measured frames following 20 warm-up frames. Error bars on the individual block curves indicate variation across timing repetitions, while the aggregate curve shows variation across blocks. }}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:rq1_fps_gaussians}{{1}{4}{Median rendering speed as a function of active Gaussian count across five pretrained blocks. Each point represents the mean of the median FPS values obtained from five repeated runs, where each run contains 300 measured frames following 20 warm-up frames. Error bars on the individual block curves indicate variation across timing repetitions, while the aggregate curve shows variation across blocks}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {1.1.8}Payload--Performance Relationship}{4}{subsubsection.1.1.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  Median rendering time as a function of active Gaussian count for five pretrained blocks. Individual curves show block-specific results, and the thicker aggregate curve shows the cross-block mean. The dashed line represents the pooled linear fit. Rendering time increases approximately linearly with the number of active Gaussians. }}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:rq1_time_gaussians}{{2}{5}{Median rendering time as a function of active Gaussian count for five pretrained blocks. Individual curves show block-specific results, and the thicker aggregate curve shows the cross-block mean. The dashed line represents the pooled linear fit. Rendering time increases approximately linearly with the number of active Gaussians}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {1.1.9}Block-Level Results}{6}{subsubsection.1.1.9}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Block-level performance at the complete Gaussian payload.}}{6}{table.caption.5}\protected@file@percent }
\newlabel{tab:rq1_full_payload_blocks}{{3}{6}{Block-level performance at the complete Gaussian payload}{table.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces  Relationship between Gaussian--tile pair count and median rendering time across all blocks and payload levels. Each marker represents one block at one payload ratio after aggregation across five timing repetitions. The fitted regression line demonstrates that projected tile coverage explains residual block-specific performance differences not captured by Gaussian count alone. }}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:rq1_time_pairs}{{3}{6}{Relationship between Gaussian--tile pair count and median rendering time across all blocks and payload levels. Each marker represents one block at one payload ratio after aggregation across five timing repetitions. The fitted regression line demonstrates that projected tile coverage explains residual block-specific performance differences not captured by Gaussian count alone}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces  Full-payload median rendering time for the five pretrained blocks. All blocks contain $50{,}000$ active Gaussians, but their rendering costs differ because their Gaussian--tile pair counts and projected spatial coverage are not identical. }}{7}{figure.caption.7}\protected@file@percent }
\newlabel{fig:rq1_full_payload_blocks}{{4}{7}{Full-payload median rendering time for the five pretrained blocks. All blocks contain $50{,}000$ active Gaussians, but their rendering costs differ because their Gaussian--tile pair counts and projected spatial coverage are not identical}{figure.caption.7}{}}
